  {
    "name": "start_live_consultation",
    "title": "Start a version-pinned Live Consultant consultation",
    "description": "Start every v0.6+ consultation here. It returns the current hosted directives, complete niche-specific skill route, compatibility state, and an opaque consultation ID that pins one answer to one knowledge release.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "query": {
          "type": "string",
          "minLength": 1,
          "maxLength": 12000,
          "description": "The specific business decision or deliverable requested."
        },
        "business_context": {
          "type": "string",
          "maxLength": 4000,
          "description": "Only task-specific business facts needed for routing, such as niche, buyer, offer, stage, geography, channel, and constraints. Do not send conversation history, raw transcripts, credentials, personal data, customer lists, or regulated data."
        },
        "client": {
          "type": "object",
          "properties": {
            "plugin_version": {
              "type": "string",
              "maxLength": 100,
              "pattern": "^(?:0|[1-9]\\d*)\\.(?:0|[1-9]\\d*)\\.(?:0|[1-9]\\d*)(?:\\+[0-9A-Za-z.-]+)?$"
            },
            "supported_contract_versions": {
              "type": "array",
              "items": {
                "type": "string",
                "maxLength": 100,
                "pattern": "^(?:0|[1-9]\\d*)\\.(?:0|[1-9]\\d*)\\.(?:0|[1-9]\\d*)$"
              },
              "minItems": 1,
              "maxItems": 8
            },
            "capabilities": {
              "type": "array",
              "items": {
                "type": "string",
                "maxLength": 100
              },
              "maxItems": 32
            },
            "extensions": {
              "type": "object",
              "additionalProperties": {
                "type": "string",
                "maxLength": 256
              }
            }
          },
          "additionalProperties": false,
          "description": "Optional non-sensitive compatibility metadata. It is not stored or included in the consultation ID."
        }
      },
      "required": [
        "query"
      ],
      "additionalProperties": false,
      "$schema": "http://json-schema.org/draft-07/schema#"
    },
    "annotations": {
      "readOnlyHint": true,
      "destructiveHint": false,
      "idempotentHint": true,
      "openWorldHint": false
    },
    "execution": {
      "taskSupport": "forbidden"
    },
    "outputSchema": {
      "type": "object",
      "properties": {
        "contract_version": {
          "type": "string",
          "const": "1.0.0"
        },
        "consultation_id": {
          "type": "string"
        },
        "knowledge_digest": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "plugin_version": {
          "type": "string"
        },
        "public_release_version": {
          "type": [
            "string",
            "null"
          ]
        },
        "runtime_directives": {
          "type": "object",
          "properties": {
            "version": {
              "type": "string"
            },
            "digest": {
              "type": "string",
              "pattern": "^[0-9a-f]{64}$"
            },
            "content": {
              "type": "string"
            }
          },
          "required": [
            "version",
            "digest",
            "content"
          ],
          "additionalProperties": false
        },
        "selected_skills": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "skill_id": {
                "type": "string"
              },
              "contribution": {
                "type": "string"
              },
              "reason": {
                "type": "string"
              },
              "bundle_files": {
                "type": "integer",
                "minimum": 0
              },
              "score": {
                "type": "number"
              }
            },
            "required": [
              "skill_id",
              "contribution",
              "reason",
              "bundle_files",
              "score"
            ],
            "additionalProperties": false
          }
        },
        "matched_routing_fixtures": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "niche_decision_fields": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "compatibility": {
          "type": "object",
          "properties": {
            "status": {
              "type": "string",
              "enum": [
                "compatible",
                "upgrade_required"
              ]
            },
            "minimum_plugin_version": {
              "type": "string"
            },
            "same_task_compatible": {
              "type": "boolean"
            },
            "message": {
              "type": "string"
            }
          },
          "required": [
            "status",
            "minimum_plugin_version",
            "same_task_compatible",
            "message"
          ],
          "additionalProperties": false
        },
        "next_step": {
          "type": "string"
        },
        "extensions": {
          "type": "object",
          "additionalProperties": {}
        }
      },
      "required": [
        "contract_version",
        "consultation_id",
        "knowledge_digest",
        "plugin_version",
        "public_release_version",
        "runtime_directives",
        "selected_skills",
        "matched_routing_fixtures",
        "niche_decision_fields",
        "compatibility",
        "next_step",
        "extensions"
      ],
      "additionalProperties": false,
      "$schema": "http://json-schema.org/draft-07/schema#"
    }
  },
